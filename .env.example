# Export-bridge configuration.
#
# LOCAL DEV: copy this file to `.env` (gitignored) and fill in the values —
#   `npm run server` loads it automatically via dotenv.
#
# PRODUCTION (Netlify): do NOT commit a .env file. Instead set these same
#   keys in the Netlify dashboard → Site settings → Environment variables.
#   Netlify injects them into the export function at runtime.
#
# Everything is OPTIONAL — with nothing set, the bridge still generates the
# PDF and degrades gracefully (it logs the lead instead of emailing).

# Port the local dev export bridge listens on (default 8787). Not used on Netlify.
PORT=8787

# SMTP — used to email the generated PDF to the user.
# Example values for a Brevo account:
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<your Brevo SMTP login>
#   SMTP_PASS=<your Brevo SMTP key>
#   MAIL_FROM=<a sender verified in Brevo>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# CRM lead bridge — a swappable webhook. The captured email + artifact
# metadata is POSTed here as JSON. Point it at any CRM intake endpoint.
# If unset, the lead is logged to the console instead.
CRM_WEBHOOK_URL=
